<?xml version="1.0" encoding="utf-8"?>
<!--
    ArgonBoard MD3 Expressive Color System 🫪
    Argon = noble gas = electric purple/blue energy ⚡
    Drop this into: app/src/main/res/values/colors.xml
-->
<resources>

    <!-- ── MD3 Expressive Primary (Electric Purple) ── -->
    <color name="argon_primary">#6750A4</color>
    <color name="argon_on_primary">#FFFFFF</color>
    <color name="argon_primary_container">#EADDFF</color>
    <color name="argon_on_primary_container">#21005D</color>

    <!-- ── Secondary (Muted Purple) ── -->
    <color name="argon_secondary">#625B71</color>
    <color name="argon_on_secondary">#FFFFFF</color>
    <color name="argon_secondary_container">#E8DEF8</color>
    <color name="argon_on_secondary_container">#1D192B</color>

    <!-- ── Tertiary (Teal accent) ── -->
    <color name="argon_tertiary">#7D5260</color>
    <color name="argon_on_tertiary">#FFFFFF</color>
    <color name="argon_tertiary_container">#FFD8E4</color>

    <!-- ── Surface (Dark mode default) ── -->
    <color name="argon_surface">#141218</color>
    <color name="argon_surface_dim">#141218</color>
    <color name="argon_surface_bright">#3B383E</color>
    <color name="argon_surface_container_lowest">#0F0D13</color>
    <color name="argon_surface_container_low">#1D1B20</color>
    <color name="argon_surface_container">#211F26</color>
    <color name="argon_surface_container_high">#2B2930</color>
    <color name="argon_surface_container_highest">#36343B</color>
    <color name="argon_on_surface">#E6E1E5</color>
    <color name="argon_on_surface_variant">#CAC4D0</color>

    <!-- ── Outline ── -->
    <color name="argon_outline">#938F99</color>
    <color name="argon_outline_variant">#49454F</color>

    <!-- ── Error ── -->
    <color name="argon_error">#F2B8B5</color>
    <color name="argon_on_error">#601410</color>

    <!-- ════════════════════════════════════════ -->
    <!--        KEYBOARD SPECIFIC COLORS          -->
    <!-- ════════════════════════════════════════ -->

    <!-- Normal keys -->
    <color name="key_bg_normal_dark">#2B2930</color>
    <color name="key_bg_normal_light">#D9D3E0</color>

    <!-- Special keys (space, enter, shift, delete) -->
    <color name="key_bg_special_dark">#4A4458</color>
    <color name="key_bg_special_light">#B9B0CC</color>

    <!-- Action key (Enter/Go/Search) — primary color pop 💜 -->
    <color name="key_bg_action_dark">#6750A4</color>
    <color name="key_bg_action_light">#6750A4</color>

    <!-- Key text -->
    <color name="key_text_primary_dark">#E6E1E5</color>
    <color name="key_text_primary_light">#1C1B1F</color>
    <color name="key_text_hint_dark">#938F99</color>
    <color name="key_text_hint_light">#49454F</color>

    <!-- Key press ripple -->
    <color name="key_ripple_dark">#4DEADDFF</color>
    <color name="key_ripple_light">#4D6750A4</color>

    <!-- Keyboard background -->
    <color name="keyboard_bg_dark">#1D1B20</color>
    <color name="keyboard_bg_light">#F4EFF4</color>

    <!-- Popup key background -->
    <color name="popup_bg_dark">#36343B</color>
    <color name="popup_bg_light">#FFFBFE</color>

    <!-- Suggestion strip -->
    <color name="suggestion_bg_dark">#211F26</color>
    <color name="suggestion_text_dark">#E6E1E5</color>
    <color name="suggestion_highlight_dark">#EADDFF</color>

</resources>
